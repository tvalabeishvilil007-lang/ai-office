# Copy this file to .env and fill in your keys.
# .env is git-ignored — keys never leave the server.

# ── Anthropic (server-side only, never exposed to browser) ────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase (server-side) ────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret — never expose to browser

# ── Supabase (frontend — safe to expose, anon key only) ───────────────────────
# These go to Vite so they're bundled into the frontend build.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # set to "production" on Railway
